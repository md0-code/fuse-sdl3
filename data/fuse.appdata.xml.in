<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>fuse.desktop</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-2.0-or-later</project_license>
  <name>Fuse</name>
  <summary>ZX Spectrum emulator with SDL3 frontend</summary>
  <developer_name>Fuse SDL3 contributors</developer_name>
  <launchable type="desktop-id">fuse.desktop</launchable>
  <description>
    <p>Fuse SDL3 is an emulator for the ZX Spectrum family and related machines, including 16K, 48K, 128K, +2, +2A, +3, Timex, Pentagon, and Scorpion systems.</p>
    <p>This downstream fork keeps the upstream emulation scope while maintaining an SDL3-based user interface and portable binary packaging.</p>
  </description>
  <url type="homepage">https://github.com/md0-code/fuse-sdl3.git</url>
  <url type="bugtracker">http://sourceforge.net/p/fuse-emulator/bugs/</url>
  <content_rating type="oars-1.1" />
  <releases>
    <release version="@PROJECT_VERSION@" date="2026-03-11" />
  </releases>
</component>