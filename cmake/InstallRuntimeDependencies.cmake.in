set(_fuse_runtime_binary "@CMAKE_BINARY_DIR@/fuse@CMAKE_EXECUTABLE_SUFFIX@")

if(NOT EXISTS "${_fuse_runtime_binary}")
  message(FATAL_ERROR "Unable to locate built Fuse executable for runtime dependency scanning: ${_fuse_runtime_binary}")
endif()

set(_fuse_runtime_destination "$ENV{DESTDIR}${CMAKE_INSTALL_PREFIX}/@FUSE_RUNTIME_LIBRARY_INSTALL_DESTINATION@")
file(MAKE_DIRECTORY "${_fuse_runtime_destination}")

set(_fuse_runtime_search_dirs_serialized [==[@FUSE_RUNTIME_SEARCH_DIRS_SERIALIZED@]==])
set(_fuse_runtime_post_exclude_serialized [==[@FUSE_RUNTIME_POST_EXCLUDE_SERIALIZED@]==])

set(_fuse_runtime_search_dirs "")
if(NOT _fuse_runtime_search_dirs_serialized STREQUAL "")
  string(REPLACE "|" ";" _fuse_runtime_search_dirs "${_fuse_runtime_search_dirs_serialized}")
endif()

set(_fuse_runtime_post_exclude_regexes "")
if(NOT _fuse_runtime_post_exclude_serialized STREQUAL "")
  string(REPLACE "|" ";" _fuse_runtime_post_exclude_regexes "${_fuse_runtime_post_exclude_serialized}")
endif()

file(GET_RUNTIME_DEPENDENCIES
  EXECUTABLES "${_fuse_runtime_binary}"
  RESOLVED_DEPENDENCIES_VAR _fuse_runtime_dependencies
  UNRESOLVED_DEPENDENCIES_VAR _fuse_runtime_unresolved
  DIRECTORIES ${_fuse_runtime_search_dirs}
  PRE_EXCLUDE_REGEXES
    "api-ms-win-.*"
    "ext-ms-.*"
    "HvsiFileTrust\\.dll"
  POST_EXCLUDE_REGEXES
    ${_fuse_runtime_post_exclude_regexes}
)

list(REMOVE_DUPLICATES _fuse_runtime_dependencies)

foreach(_fuse_runtime_dependency IN LISTS _fuse_runtime_dependencies)
  # Resolve to the real file so the package contains actual libraries, not symlinks.
  file(REAL_PATH "${_fuse_runtime_dependency}" _fuse_runtime_real_path)
  get_filename_component(_fuse_runtime_soname "${_fuse_runtime_dependency}" NAME)
  set(_fuse_runtime_installed_path "${_fuse_runtime_destination}/${_fuse_runtime_soname}")
  file(COPY_FILE "${_fuse_runtime_real_path}" "${_fuse_runtime_installed_path}")
endforeach()

if(_fuse_runtime_unresolved)
  list(JOIN _fuse_runtime_unresolved ", " _fuse_runtime_unresolved_text)
  message(WARNING "Unresolved runtime dependencies while bundling Fuse: ${_fuse_runtime_unresolved_text}")
endif()